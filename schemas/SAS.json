{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "http://openconverters.com/schemas/SAS/SAS.json",
    "title": "SAS",
    "description": "Semiconductor Agnostic Structure (SAS). A document carries inputs, exactly one of {mosfet, diode, igbt, bjt} (the field name is the discriminator), and outputs.",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "inputs": {
            "description": "Design requirements and operating points for this semiconductor",
            "title": "inputs",
            "$ref": "./inputs.json"
        },
        "mosfet": {
            "description": "MOSFET (Si, SiC, GaN, GaAs)",
            "title": "mosfet",
            "$ref": "./mosfet.json"
        },
        "diode": {
            "description": "Diode (Schottky, ultrafast, SiC Schottky, Zener, TVS)",
            "title": "diode",
            "$ref": "./diode.json"
        },
        "igbt": {
            "description": "IGBT",
            "title": "igbt",
            "$ref": "./igbt.json"
        },
        "bjt": {
            "description": "BJT (npn or pnp)",
            "title": "bjt",
            "$ref": "./bjt.json"
        },
        "outputs": {
            "description": "Computed results per operating point. outputs[i] aligns positionally with inputs.operatingPoints[i].",
            "title": "outputs",
            "type": "array",
            "items": {
                "$ref": "./outputs.json"
            }
        }
    },
    "required": [
        "inputs",
        "outputs"
    ],
    "oneOf": [
        {
            "required": [
                "mosfet"
            ]
        },
        {
            "required": [
                "diode"
            ]
        },
        {
            "required": [
                "igbt"
            ]
        },
        {
            "required": [
                "bjt"
            ]
        }
    ]
}
