{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "http://openconverters.com/schemas/SAS/outputs.json",
    "$comment": "SPDX-License-Identifier: Apache-2.0",
    "title": "outputs",
    "description": "Outputs computed for one operating point of a semiconductor. Each named block is independently optional; every block carries the PEAS outputBase {origin, methodUsed} provenance shell. The top-level SAS document holds an array of these — outputs[i] aligns positionally with inputs.operatingPoints[i].",
    "type": "object",
    "properties": {
        "conductionLosses": {
            "description": "Steady-state on-state losses (I^2 * R_DS(on) for MOSFETs, V_F * I_F for diodes, V_CE(sat) * I_C for IGBTs/BJTs).",
            "$ref": "#/$defs/conductionLossesOutput"
        },
        "switchingLosses": {
            "description": "Switching losses per cycle (E_on + E_off) and average power, scaled by the switching frequency.",
            "$ref": "#/$defs/switchingLossesOutput"
        },
        "reverseRecoveryLosses": {
            "description": "Diode / body-diode reverse recovery losses.",
            "$ref": "#/$defs/reverseRecoveryLossesOutput"
        },
        "gateDriveEnergy": {
            "description": "Energy required by the gate driver (Q_g * V_drive * f_sw).",
            "$ref": "#/$defs/gateDriveEnergyOutput"
        },
        "totalPowerDissipation": {
            "description": "Sum of conduction + switching + reverse recovery + gate drive contributions.",
            "$ref": "#/$defs/totalPowerDissipationOutput"
        },
        "junctionTemperature": {
            "description": "Junction temperature reached at the operating point.",
            "$ref": "#/$defs/junctionTemperatureOutput"
        },
        "soaCheck": {
            "description": "Safe-Operating-Area excursion check.",
            "$ref": "#/$defs/soaCheckOutput"
        },
        "lifetime": {
            "description": "Predicted wear-out / thermal-cycling lifetime.",
            "$ref": "#/$defs/lifetimeOutput"
        },
        "isolationCheck": {
            "description": "Insulation coordination figures, for isolated parts (gate drivers, optocouplers).",
            "$ref": "../../PEAS/schemas/outputs/insulationCoordination.json"
        }
    },
    "required": [],
    "$defs": {
        "conductionLossesOutput": {
            "title": "conductionLossesOutput",
            "allOf": [
                {
                    "$ref": "../../PEAS/schemas/outputs/outputBase.json"
                },
                {
                    "type": "object",
                    "properties": {
                        "totalConductionLosses": {
                            "description": "Average conduction power dissipation, in W.",
                            "type": "number",
                            "minimum": 0
                        },
                        "rmsCurrent": {
                            "description": "RMS conduction current, in A.",
                            "type": "number",
                            "minimum": 0
                        },
                        "averageCurrent": {
                            "description": "Average conduction current, in A.",
                            "type": "number"
                        },
                        "onStateResistance": {
                            "description": "R_DS(on) (or equivalent) used in the calculation, in Ohm.",
                            "type": "number",
                            "minimum": 0
                        },
                        "onStateVoltageDrop": {
                            "description": "V_F or V_CE(sat) used in the calculation, in V.",
                            "type": "number"
                        },
                        "conditions": {
                            "$ref": "../../PEAS/schemas/outputs/measurementCondition.json"
                        }
                    },
                    "required": [
                        "totalConductionLosses"
                    ]
                }
            ]
        },
        "switchingLossesOutput": {
            "title": "switchingLossesOutput",
            "allOf": [
                {
                    "$ref": "../../PEAS/schemas/outputs/outputBase.json"
                },
                {
                    "type": "object",
                    "properties": {
                        "energyPerTurnOn": {
                            "description": "Switching energy per turn-on event E_on, in J.",
                            "type": "number",
                            "minimum": 0
                        },
                        "energyPerTurnOff": {
                            "description": "Switching energy per turn-off event E_off, in J.",
                            "type": "number",
                            "minimum": 0
                        },
                        "energyPerCycle": {
                            "description": "Total switching energy per cycle (E_on + E_off), in J.",
                            "type": "number",
                            "minimum": 0
                        },
                        "averagePower": {
                            "description": "Average switching power dissipation, energyPerCycle * f_sw, in W.",
                            "type": "number",
                            "minimum": 0
                        },
                        "switchingFrequency": {
                            "description": "Switching frequency at which the average is computed, in Hz.",
                            "type": "number",
                            "exclusiveMinimum": 0
                        },
                        "conditions": {
                            "description": "V_DS, I_D, R_g, T_j at which the switching energies were extracted.",
                            "$ref": "../../PEAS/schemas/outputs/measurementCondition.json"
                        }
                    },
                    "required": [
                        "energyPerCycle"
                    ]
                }
            ]
        },
        "reverseRecoveryLossesOutput": {
            "title": "reverseRecoveryLossesOutput",
            "allOf": [
                {
                    "$ref": "../../PEAS/schemas/outputs/outputBase.json"
                },
                {
                    "type": "object",
                    "properties": {
                        "qrr": {
                            "description": "Reverse recovery charge Q_rr at the operating point, in C.",
                            "type": "number",
                            "minimum": 0
                        },
                        "trr": {
                            "description": "Reverse recovery time t_rr, in s.",
                            "type": "number",
                            "minimum": 0
                        },
                        "energyPerEvent": {
                            "description": "Reverse recovery energy per commutation, in J.",
                            "type": "number",
                            "minimum": 0
                        },
                        "averagePower": {
                            "description": "Average reverse recovery power, in W.",
                            "type": "number",
                            "minimum": 0
                        },
                        "conditions": {
                            "$ref": "../../PEAS/schemas/outputs/measurementCondition.json"
                        }
                    },
                    "required": [
                        "averagePower"
                    ]
                }
            ]
        },
        "gateDriveEnergyOutput": {
            "title": "gateDriveEnergyOutput",
            "allOf": [
                {
                    "$ref": "../../PEAS/schemas/outputs/outputBase.json"
                },
                {
                    "type": "object",
                    "properties": {
                        "totalGateCharge": {
                            "description": "Total gate charge Q_g at the operating drive voltage, in C.",
                            "type": "number",
                            "minimum": 0
                        },
                        "driveVoltageSwing": {
                            "description": "Drive voltage swing applied to the gate, in V.",
                            "type": "number",
                            "exclusiveMinimum": 0
                        },
                        "energyPerCycle": {
                            "description": "Gate drive energy per switching cycle (Q_g * V_drive), in J.",
                            "type": "number",
                            "minimum": 0
                        },
                        "averagePower": {
                            "description": "Average gate drive power dissipation, in W.",
                            "type": "number",
                            "minimum": 0
                        }
                    },
                    "required": [
                        "averagePower"
                    ]
                }
            ]
        },
        "totalPowerDissipationOutput": {
            "title": "totalPowerDissipationOutput",
            "allOf": [
                {
                    "$ref": "../../PEAS/schemas/outputs/outputBase.json"
                },
                {
                    "type": "object",
                    "properties": {
                        "total": {
                            "description": "Sum of all loss contributions at the operating point, in W.",
                            "type": "number",
                            "minimum": 0
                        },
                        "conductionShare": {
                            "description": "Share of total contributed by conduction losses (0..1).",
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                        },
                        "switchingShare": {
                            "description": "Share of total contributed by switching losses (0..1).",
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                        },
                        "reverseRecoveryShare": {
                            "description": "Share of total contributed by reverse recovery losses (0..1).",
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                        },
                        "gateDriveShare": {
                            "description": "Share of total contributed by gate drive losses (0..1).",
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                        }
                    },
                    "required": [
                        "total"
                    ]
                }
            ]
        },
        "junctionTemperatureOutput": {
            "title": "junctionTemperatureOutput",
            "allOf": [
                {
                    "$ref": "../../PEAS/schemas/outputs/outputBase.json"
                },
                {
                    "type": "object",
                    "properties": {
                        "junctionTemperature": {
                            "description": "Steady-state junction temperature, in Celsius.",
                            "type": "number"
                        },
                        "caseTemperature": {
                            "description": "Case temperature used as the boundary condition, in Celsius.",
                            "type": "number"
                        },
                        "ambientTemperature": {
                            "description": "Ambient temperature used in the thermal network, in Celsius.",
                            "type": "number"
                        },
                        "thermalResistanceJunctionToCase": {
                            "description": "R_th(j-c) used in the calculation, in K/W.",
                            "type": "number",
                            "minimum": 0
                        },
                        "thermalResistanceCaseToAmbient": {
                            "description": "R_th(c-a) used in the calculation (heatsink + interface + ambient path), in K/W.",
                            "type": "number",
                            "minimum": 0
                        }
                    },
                    "required": [
                        "junctionTemperature"
                    ]
                }
            ]
        },
        "soaCheckOutput": {
            "title": "soaCheckOutput",
            "description": "Safe Operating Area check. Compares the operating-point trajectory in the V-I plane against the device's SOA contour and reports whether it stays inside.",
            "allOf": [
                {
                    "$ref": "../../PEAS/schemas/outputs/outputBase.json"
                },
                {
                    "type": "object",
                    "properties": {
                        "passes": {
                            "description": "Whether the entire trajectory stays inside the SOA contour.",
                            "type": "boolean"
                        },
                        "worstMargin": {
                            "description": "Smallest distance from the SOA boundary along the trajectory, dimensionless ratio. Negative means the boundary is exceeded.",
                            "type": "number"
                        },
                        "appliedTrajectory": {
                            "description": "V-I trajectory sampled along the operating point. Index-aligned arrays.",
                            "type": "object",
                            "properties": {
                                "voltage": {
                                    "type": "array",
                                    "items": {
                                        "type": "number"
                                    }
                                },
                                "current": {
                                    "type": "array",
                                    "items": {
                                        "type": "number"
                                    }
                                },
                                "time": {
                                    "type": "array",
                                    "items": {
                                        "type": "number"
                                    }
                                }
                            }
                        },
                        "failurePoint": {
                            "description": "Point on the trajectory at which the SOA contour is first exceeded; absent if passes is true.",
                            "type": "object",
                            "properties": {
                                "voltage": {
                                    "type": "number"
                                },
                                "current": {
                                    "type": "number"
                                },
                                "time": {
                                    "type": "number"
                                }
                            }
                        }
                    },
                    "required": [
                        "passes"
                    ]
                }
            ]
        },
        "lifetimeOutput": {
            "title": "lifetimeOutput",
            "allOf": [
                {
                    "$ref": "../../PEAS/schemas/outputs/outputBase.json"
                },
                {
                    "type": "object",
                    "properties": {
                        "predictedHours": {
                            "description": "Predicted lifetime under the operating point, in hours.",
                            "$ref": "../../PEAS/schemas/utils.json#/$defs/dimensionWithTolerance"
                        },
                        "thermalCycles": {
                            "description": "Predicted number of thermal cycles to wear-out under the operating point.",
                            "type": "integer",
                            "minimum": 0
                        },
                        "endOfLifeMode": {
                            "description": "Predicted dominant wear-out mechanism.",
                            "type": "string",
                            "enum": [
                                "bondWireFatigue",
                                "solderFatigue",
                                "gateOxideWear",
                                "electromigration",
                                "thermalRunaway",
                                "shortCircuit",
                                "openCircuit"
                            ]
                        },
                        "conditions": {
                            "$ref": "../../PEAS/schemas/outputs/measurementCondition.json"
                        }
                    },
                    "required": [
                        "predictedHours"
                    ]
                }
            ]
        }
    }
}
