{
    "description": "Semiconductor Agnostic Structure (SAS). Discriminates by deviceType: each type has its own electrical specs, SPICE params, and curves \u2014 no empty fields.",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "http://openconverters.com/schemas/SAS/semiconductor.json",
    "title": "semiconductor",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "manufacturerInfo": {
            "$ref": "#/$defs/manufacturerInfo"
        },
        "distributorsInfo": {
            "description": "Where to buy this component",
            "type": "array",
            "items": {
                "$ref": "./utils.json#/$defs/distributorInfo"
            }
        },
        "substitutesInfo": {
            "description": "Substitute or equivalent components that can replace this one",
            "type": "array",
            "items": {
                "$ref": "./utils.json#/$defs/substituteInfo"
            }
        },
        "inputs": {
            "description": "High-level design inputs (used by MOSFET/IGBT wrapper entries)",
            "type": "object"
        },
        "semiconductor": {
            "description": "Semiconductor data wrapper (used by MOSFET/IGBT entries)",
            "type": "object"
        },
        "outputs": {
            "description": "Design outputs / metadata (used by MOSFET/IGBT wrapper entries)",
            "type": "object"
        }
    },
    "required": [],
    "$defs": {
        "manufacturerInfo": {
            "description": "Manufacturer-specific information \u2014 extends EAS base with semiconductor-specific datasheetInfo.",
            "allOf": [
                {
                    "$ref": "http://openconverters.com/schemas/EAS/utils.json#/$defs/manufacturerInfo"
                },
                {
                    "type": "object",
                    "properties": {
                        "datasheetInfo": {
                            "$ref": "#/$defs/datasheetInfo"
                        }
                    },
                    "required": [
                        "datasheetInfo"
                    ]
                }
            ]
        },
        "datasheetInfo": {
            "description": "All information extracted from the datasheet. Shared sections (part, thermal, mechanical, business) plus device-type-specific sections via oneOf.",
            "type": "object",
            "unevaluatedProperties": false,
            "properties": {
                "part": {
                    "$ref": "#/$defs/part"
                },
                "thermal": {
                    "$ref": "#/$defs/thermal"
                },
                "mechanical": {
                    "$ref": "#/$defs/mechanical"
                },
                "business": {
                    "$ref": "#/$defs/business"
                },
                "_needsVerification": {
                    "description": "Audit flag: one or more fields need cross-checking against real datasheet",
                    "type": [
                        "boolean",
                        "null"
                    ]
                },
                "_verificationNote": {
                    "description": "Audit note explaining what needs verification",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "_verificationNotes": {
                    "description": "Audit notes (plural form) explaining what needs verification",
                    "type": [
                        "string",
                        "null"
                    ]
                }
            },
            "required": [
                "part"
            ],
            "oneOf": [
                {
                    "description": "MOSFET (Si, SiC, GaN)",
                    "properties": {
                        "part": {
                            "properties": {
                                "deviceType": {
                                    "const": "mosfet"
                                }
                            }
                        },
                        "electrical": {
                            "$ref": "#/$defs/mosfetElectrical"
                        },
                        "modelParams": {
                            "$ref": "#/$defs/mosfetModelParams"
                        },
                        "curves": {
                            "$ref": "#/$defs/mosfetCurves"
                        }
                    },
                    "required": [
                        "electrical"
                    ]
                },
                {
                    "description": "Diode (Schottky, ultrafast, SiC Schottky, Zener, TVS)",
                    "properties": {
                        "part": {
                            "properties": {
                                "deviceType": {
                                    "const": "diode"
                                }
                            }
                        },
                        "electrical": {
                            "$ref": "#/$defs/diodeElectrical"
                        },
                        "modelParams": {
                            "$ref": "#/$defs/diodeModelParams"
                        },
                        "curves": {
                            "$ref": "#/$defs/diodeCurves"
                        }
                    },
                    "required": [
                        "electrical"
                    ]
                },
                {
                    "description": "IGBT",
                    "properties": {
                        "part": {
                            "properties": {
                                "deviceType": {
                                    "const": "igbt"
                                }
                            }
                        },
                        "electrical": {
                            "$ref": "#/$defs/igbtElectrical"
                        },
                        "modelParams": {
                            "$ref": "#/$defs/igbtModelParams"
                        },
                        "curves": {
                            "$ref": "#/$defs/igbtCurves"
                        }
                    },
                    "required": [
                        "electrical"
                    ]
                },
                {
                    "description": "BJT",
                    "properties": {
                        "part": {
                            "properties": {
                                "deviceType": {
                                    "const": "bjt"
                                }
                            }
                        },
                        "electrical": {
                            "$ref": "#/$defs/bjtElectrical"
                        }
                    },
                    "required": [
                        "electrical"
                    ]
                }
            ]
        },
        "part": {
            "description": "Basic part identification \u2014 shared across all semiconductor types",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "partNumber": {
                    "type": "string"
                },
                "series": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "deviceType": {
                    "type": "string",
                    "enum": [
                        "mosfet",
                        "diode",
                        "igbt",
                        "bjt",
                        "jfet"
                    ]
                },
                "technology": {
                    "type": "string",
                    "enum": [
                        "Si",
                        "SiC",
                        "GaN",
                        "GaAs"
                    ]
                },
                "subType": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "MOSFET: nChannel/pChannel. Diode: schottky/sicSchottky/ultrafast/fastRecovery/fast/standard/zener/tvs. IGBT: nChannel. BJT: npn/pnp",
                    "enum": [
                        "nChannel",
                        "pChannel",
                        "schottky",
                        "sicSchottky",
                        "ultrafast",
                        "fastRecovery",
                        "fast",
                        "standard",
                        "zener",
                        "tvs",
                        "npn",
                        "pnp",
                        null
                    ]
                },
                "case": {
                    "type": "string",
                    "description": "Package code (TO-220, SOT-23, etc.)"
                },
                "matchcodeDescription": {
                    "type": [
                        "string",
                        "null"
                    ]
                }
            },
            "required": [
                "partNumber",
                "deviceType",
                "technology"
            ]
        },
        "mosfetElectrical": {
            "description": "MOSFET electrical characteristics \u2014 every field is relevant to MOSFETs",
            "type": "object",
            "properties": {
                "drainSourceVoltage": {
                    "type": "number",
                    "description": "V_DS max in Volts"
                },
                "gateSourceVoltageMax": {
                    "type": "number",
                    "description": "V_GS max in Volts"
                },
                "continuousDrainCurrent": {
                    "type": "number",
                    "description": "I_D at Tc=25C in Amperes"
                },
                "continuousDrainCurrentAt100C": {
                    "type": "number",
                    "description": "I_D at Tc=100C in Amperes"
                },
                "pulsedDrainCurrent": {
                    "type": "number",
                    "description": "I_DM in Amperes"
                },
                "powerDissipation": {
                    "type": "number",
                    "description": "P_D max at Tc=25C in Watts"
                },
                "avalancheEnergy": {
                    "type": "number",
                    "description": "E_AS in Joules"
                },
                "onResistance": {
                    "type": "number",
                    "description": "R_DS(on) in Ohms"
                },
                "onResistanceVgs": {
                    "type": "number",
                    "description": "V_GS for R_DS(on) spec in Volts"
                },
                "onResistanceId": {
                    "type": "number",
                    "description": "I_D for R_DS(on) spec in Amperes"
                },
                "gateThresholdVoltage": {
                    "$ref": "./utils.json#/$defs/dimensionWithTolerance",
                    "description": "V_GS(th) in Volts"
                },
                "inputCapacitance": {
                    "type": "number",
                    "description": "C_iss in Farads"
                },
                "outputCapacitance": {
                    "type": "number",
                    "description": "C_oss in Farads"
                },
                "reverseTransferCapacitance": {
                    "type": "number",
                    "description": "C_rss in Farads"
                },
                "capacitanceMeasurementVds": {
                    "type": "number",
                    "description": "V_DS for cap measurement in Volts"
                },
                "totalGateCharge": {
                    "type": "number",
                    "description": "Q_g in Coulombs"
                },
                "gateSourceCharge": {
                    "type": "number",
                    "description": "Q_gs in Coulombs"
                },
                "gateDrainCharge": {
                    "type": "number",
                    "description": "Q_gd in Coulombs"
                },
                "outputCharge": {
                    "type": "number",
                    "description": "Q_oss in Coulombs"
                },
                "turnOnDelay": {
                    "type": "number",
                    "description": "t_d(on) in seconds"
                },
                "riseTime": {
                    "type": "number",
                    "description": "t_r in seconds"
                },
                "turnOffDelay": {
                    "type": "number",
                    "description": "t_d(off) in seconds"
                },
                "fallTime": {
                    "type": "number",
                    "description": "t_f in seconds"
                },
                "bodyDiodeForwardVoltage": {
                    "type": "number",
                    "description": "V_SD in Volts"
                },
                "bodyDiodeContinuousCurrent": {
                    "type": "number",
                    "description": "I_S in Amperes"
                },
                "reverseRecoveryTime": {
                    "type": "number",
                    "description": "t_rr in seconds"
                },
                "reverseRecoveryCharge": {
                    "type": "number",
                    "description": "Q_rr in Coulombs"
                },
                "figureOfMerit": {
                    "type": "number",
                    "description": "R_DS(on) x Q_g in Ohm-Coulombs"
                }
            },
            "required": [
                "drainSourceVoltage",
                "onResistance",
                "continuousDrainCurrent"
            ]
        },
        "diodeElectrical": {
            "description": "Diode electrical characteristics \u2014 every field is relevant to diodes",
            "type": "object",
            "properties": {
                "reverseVoltage": {
                    "type": "number",
                    "description": "V_RRM in Volts"
                },
                "forwardCurrent": {
                    "type": "number",
                    "description": "I_F(AV) in Amperes"
                },
                "surgeCurrent": {
                    "type": "number",
                    "description": "I_FSM in Amperes"
                },
                "forwardVoltage": {
                    "type": "number",
                    "description": "V_F in Volts"
                },
                "forwardVoltageAt": {
                    "type": "number",
                    "description": "I_F at which V_F is specified in Amperes"
                },
                "reverseLeakageCurrent": {
                    "type": "number",
                    "description": "I_R in Amperes"
                },
                "reverseRecoveryTime": {
                    "type": "number",
                    "description": "t_rr in seconds"
                },
                "reverseRecoveryCharge": {
                    "type": "number",
                    "description": "Q_rr in Coulombs"
                },
                "junctionCapacitance": {
                    "type": "number",
                    "description": "C_j in Farads"
                },
                "junctionCapacitanceVr": {
                    "type": "number",
                    "description": "V_R for C_j measurement in Volts"
                },
                "powerDissipation": {
                    "type": "number",
                    "description": "P_D max in Watts"
                },
                "clampingVoltage": {
                    "type": "number",
                    "description": "V_C at I_PP for TVS in Volts"
                },
                "breakdownVoltage": {
                    "$ref": "./utils.json#/$defs/dimensionWithTolerance",
                    "description": "V_BR for Zener/TVS in Volts"
                },
                "standoffVoltage": {
                    "type": "number",
                    "description": "V_WM working voltage for TVS in Volts"
                },
                "peakPulseCurrent": {
                    "type": "number",
                    "description": "I_PP for TVS in Amperes"
                }
            },
            "required": [
                "reverseVoltage",
                "forwardVoltage",
                "forwardCurrent"
            ]
        },
        "igbtElectrical": {
            "description": "IGBT electrical characteristics",
            "type": "object",
            "properties": {
                "collectorEmitterVoltage": {
                    "type": "number",
                    "description": "V_CE max in Volts"
                },
                "gateEmitterVoltageMax": {
                    "type": "number",
                    "description": "V_GE max in Volts"
                },
                "continuousCollectorCurrent": {
                    "type": "number",
                    "description": "I_C at Tc=25C in Amperes"
                },
                "collectorEmitterSaturation": {
                    "type": "number",
                    "description": "V_CE(sat) in Volts"
                },
                "collectorEmitterSaturationIc": {
                    "type": "number",
                    "description": "I_C for V_CE(sat) spec in Amperes"
                },
                "turnOnEnergy": {
                    "type": "number",
                    "description": "E_on in Joules"
                },
                "turnOffEnergy": {
                    "type": "number",
                    "description": "E_off in Joules"
                },
                "totalGateCharge": {
                    "type": "number",
                    "description": "Q_g in Coulombs"
                },
                "gateThresholdVoltage": {
                    "$ref": "./utils.json#/$defs/dimensionWithTolerance"
                },
                "inputCapacitance": {
                    "type": "number",
                    "description": "C_ies in Farads"
                },
                "powerDissipation": {
                    "type": "number",
                    "description": "P_D max in Watts"
                },
                "shortCircuitTime": {
                    "type": "number",
                    "description": "t_SC in seconds"
                }
            },
            "required": [
                "collectorEmitterVoltage",
                "collectorEmitterSaturation",
                "continuousCollectorCurrent"
            ]
        },
        "bjtElectrical": {
            "description": "BJT electrical characteristics",
            "type": "object",
            "properties": {
                "collectorEmitterVoltage": {
                    "type": "number",
                    "description": "V_CEO in Volts"
                },
                "collectorBasevoltage": {
                    "type": "number",
                    "description": "V_CBO in Volts"
                },
                "collectorCurrent": {
                    "type": "number",
                    "description": "I_C max in Amperes"
                },
                "dcCurrentGain": {
                    "$ref": "./utils.json#/$defs/dimensionWithTolerance",
                    "description": "h_FE"
                },
                "saturationVoltage": {
                    "type": "number",
                    "description": "V_CE(sat) in Volts"
                },
                "transitionFrequency": {
                    "type": "number",
                    "description": "f_T in Hz"
                },
                "powerDissipation": {
                    "type": "number",
                    "description": "P_D max in Watts"
                }
            },
            "required": [
                "collectorEmitterVoltage",
                "collectorCurrent"
            ]
        },
        "mosfetModelParams": {
            "description": "SPICE model parameters for MOSFET",
            "type": "object",
            "properties": {
                "level": {
                    "type": "integer",
                    "description": "SPICE model level"
                },
                "vto": {
                    "type": "number",
                    "description": "Threshold voltage in Volts"
                },
                "kp": {
                    "type": "number",
                    "description": "Transconductance in A/V^2"
                },
                "lambda": {
                    "type": "number",
                    "description": "Channel-length modulation in 1/V"
                },
                "rd": {
                    "type": "number",
                    "description": "Drain resistance in Ohms"
                },
                "rs": {
                    "type": "number",
                    "description": "Source resistance in Ohms"
                },
                "cgs": {
                    "type": "number",
                    "description": "Gate-source capacitance in Farads"
                },
                "cgd": {
                    "type": "number",
                    "description": "Gate-drain capacitance in Farads"
                },
                "cds": {
                    "type": "number",
                    "description": "Drain-source capacitance in Farads"
                },
                "is": {
                    "type": "number",
                    "description": "Body diode saturation current in Amperes"
                },
                "n": {
                    "type": "number",
                    "description": "Body diode ideality factor"
                }
            }
        },
        "diodeModelParams": {
            "description": "SPICE model parameters for diode",
            "type": "object",
            "properties": {
                "is": {
                    "type": "number",
                    "description": "Saturation current in Amperes"
                },
                "n": {
                    "type": "number",
                    "description": "Ideality factor"
                },
                "rs": {
                    "type": "number",
                    "description": "Series resistance in Ohms"
                },
                "cj0": {
                    "type": "number",
                    "description": "Zero-bias junction capacitance in Farads"
                },
                "vj": {
                    "type": "number",
                    "description": "Junction potential in Volts"
                },
                "m": {
                    "type": "number",
                    "description": "Grading coefficient"
                },
                "tt": {
                    "type": "number",
                    "description": "Transit time in seconds"
                },
                "bv": {
                    "type": "number",
                    "description": "Breakdown voltage in Volts"
                },
                "ibv": {
                    "type": "number",
                    "description": "Current at breakdown in Amperes"
                }
            }
        },
        "igbtModelParams": {
            "description": "SPICE model parameters for IGBT",
            "type": "object",
            "properties": {
                "vto": {
                    "type": "number"
                },
                "kp": {
                    "type": "number"
                },
                "eon": {
                    "type": "number",
                    "description": "Turn-on energy in Joules"
                },
                "eoff": {
                    "type": "number",
                    "description": "Turn-off energy in Joules"
                }
            }
        },
        "mosfetCurves": {
            "description": "MOSFET characteristic curves from datasheet",
            "type": "object",
            "properties": {
                "rdsOnVsTj": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "R_DS(on) vs Tj"
                },
                "rdsOnVsId": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "R_DS(on) vs I_D"
                },
                "cissVsVds": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "C_iss vs V_DS"
                },
                "cossVsVds": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "C_oss vs V_DS"
                },
                "crssVsVds": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "C_rss vs V_DS"
                },
                "gateCharge": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "V_GS vs Q_g"
                },
                "bodyDiodeVf": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "V_SD vs I_SD"
                },
                "soa": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "Safe Operating Area"
                },
                "thermalImpedance": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "Z_th(j-c) vs pulse width"
                }
            }
        },
        "diodeCurves": {
            "description": "Diode characteristic curves from datasheet",
            "type": "object",
            "properties": {
                "forwardVoltageVsCurrent": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "V_F vs I_F"
                },
                "forwardVoltageVsTj": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "V_F vs Tj"
                },
                "reverseCurrentVsVoltage": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "I_R vs V_R"
                },
                "capacitanceVsVoltage": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "C_j vs V_R"
                },
                "thermalImpedance": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "Z_th(j-c) vs pulse width"
                },
                "soa": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "Safe Operating Area"
                }
            }
        },
        "igbtCurves": {
            "description": "IGBT characteristic curves from datasheet",
            "type": "object",
            "properties": {
                "vceVsIc": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "V_CE(sat) vs I_C"
                },
                "eonVsIc": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "E_on vs I_C"
                },
                "eoffVsIc": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "E_off vs I_C"
                },
                "thermalImpedance": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "Z_th(j-c) vs pulse width"
                },
                "soa": {
                    "$ref": "./utils.json#/$defs/curve",
                    "description": "Safe Operating Area"
                }
            }
        },
        "thermal": {
            "description": "Thermal characteristics \u2014 shared across all semiconductor types",
            "type": "object",
            "properties": {
                "thermalResistanceJunctionCase": {
                    "type": "number",
                    "description": "R_th(j-c) in K/W"
                },
                "thermalResistanceJunctionAmbient": {
                    "type": "number",
                    "description": "R_th(j-a) in K/W"
                },
                "thermalResistanceCaseSink": {
                    "type": "number",
                    "description": "R_th(c-s) in K/W"
                },
                "junctionTemperatureMax": {
                    "type": "number",
                    "description": "T_j max in Celsius"
                },
                "junctionTemperatureMin": {
                    "type": "number",
                    "description": "T_j min in Celsius"
                },
                "fosterNetwork": {
                    "description": "Foster RC network for transient thermal impedance",
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "resistance": {
                                "type": "number",
                                "description": "K/W"
                            },
                            "timeConstant": {
                                "type": "number",
                                "description": "seconds"
                            }
                        },
                        "required": [
                            "resistance",
                            "timeConstant"
                        ]
                    }
                }
            }
        },
        "mechanical": {
            "description": "Mechanical specs \u2014 shared across all semiconductor types",
            "type": "object",
            "properties": {
                "assemblyType": {
                    "description": "PCB mounting / assembly type",
                    "$ref": "./utils.json#/$defs/connectionType"
                },
                "case": {
                    "type": "string",
                    "description": "Package name (TO-220, SOT-23, etc.)"
                },
                "length": {
                    "description": "Body length in meters",
                    "$ref": "./utils.json#/$defs/dimensionWithTolerance"
                },
                "width": {
                    "description": "Body width in meters",
                    "$ref": "./utils.json#/$defs/dimensionWithTolerance"
                },
                "height": {
                    "description": "Body height in meters",
                    "$ref": "./utils.json#/$defs/dimensionWithTolerance"
                },
                "weight": {
                    "type": "number",
                    "description": "kg"
                }
            }
        },
        "business": {
            "description": "Commercial info \u2014 shared across all semiconductor types",
            "type": "object",
            "properties": {
                "packaging": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "vpe": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "description": "Units per package"
                },
                "moq": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "description": "Minimum order quantity"
                },
                "leadTime": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "description": "weeks"
                },
                "stock": {
                    "type": [
                        "integer",
                        "null"
                    ]
                },
                "cost": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "description": "unit cost"
                }
            }
        }
    }
}